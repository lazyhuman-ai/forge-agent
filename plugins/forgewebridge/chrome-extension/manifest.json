{
  "manifest_version": 3,
  "name": "ForgeWebridge",
  "version": "0.5.3",
  "description": "Bridge ForgeAgent browser tools to this Chrome profile's visible logged-in pages.",
  "permissions": ["alarms", "scripting", "storage", "tabs"],
  "host_permissions": ["http://127.0.0.1/*", "http://localhost/*", "http://[::1]/*", "http://*/*", "https://*/*"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_page": "options.html",
  "action": {
    "default_title": "ForgeWebridge",
    "default_popup": "options.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
